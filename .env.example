# ═══════════════════════════════════════════════════════════════════════════════
# FIFA World Cup 2026 Platform — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real API keys.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────────────────────
# Standard Node.js env — Next.js uses this automatically.
NODE_ENV=development

# Public vars (prefixed NEXT_PUBLIC_) are safe to expose to the browser.
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_NAME="FIFA World Cup 2026"

# Matches FOOTBALL_COMPETITION below — used by client components for display.
NEXT_PUBLIC_COMPETITION=wc2026

# ── Active Competition ─────────────────────────────────────────────────────────
# Selects which competition's tournament IDs and date range are used.
#
# Allowed values:
#   wc2026            FIFA World Cup 2026        (Jun 11 – Jul 19, 2026)
#   euro2024          UEFA Euro 2024             (Jun 14 – Jul 14, 2024)
#   copa-america-2024 Copa America 2024          (Jun 20 – Jul 14, 2024)
#   ucl               UEFA Champions League      (Sep 2024 – May 2025)
#   premier-league    Premier League 2024-25     (Aug 2024 – May 2025)
#   la-liga           La Liga 2024-25            (Aug 2024 – May 2025)
FOOTBALL_COMPETITION=wc2026

# ── Provider Chain ─────────────────────────────────────────────────────────────
# FOOTBALL_PROVIDER  — primary data source (required)
# FOOTBALL_FALLBACK  — comma-separated list tried in order if primary fails
#
# Allowed values: api-football | sportmonks | sportradar
FOOTBALL_PROVIDER=api-football
FOOTBALL_FALLBACK=

# ── API-Football (api-sports.io / RapidAPI) ────────────────────────────────────
# https://www.api-football.com
# Plan: Free tier = 100 requests/day; Pro = unlimited
API_FOOTBALL_KEY=
API_FOOTBALL_HOST=v3.football.api-sports.io
API_FOOTBALL_RATE_LIMIT_MINUTE=30
API_FOOTBALL_RATE_LIMIT_DAY=100

# ── SportMonks (sportmonks.com) ────────────────────────────────────────────────
# https://www.sportmonks.com/football-api/
# Plan: Starter = 3 000 req/day; Business = 30 000 req/day
SPORTMONKS_TOKEN=
SPORTMONKS_RATE_LIMIT_MINUTE=100
SPORTMONKS_RATE_LIMIT_DAY=3000

# ── Sportradar (sportradar.com) ────────────────────────────────────────────────
# https://developer.sportradar.com/soccer/reference
# Trial tier: 1 req/second, 1 000 req/day
# access_level: trial | production
SPORTRADAR_KEY=
SPORTRADAR_ACCESS_LEVEL=trial
SPORTRADAR_RATE_LIMIT_MINUTE=1
SPORTRADAR_RATE_LIMIT_DAY=1000

# ── Cache TTLs (seconds) ───────────────────────────────────────────────────────
# Tune these to balance freshness vs. provider API quota usage.
CACHE_LIVE_MATCH_TTL=15       # live score polling interval
CACHE_MATCH_DETAIL_TTL=60     # single match with events
CACHE_FIXTURES_TTL=300        # scheduled fixture list (5 min)
CACHE_STANDINGS_TTL=300       # group standings (5 min)
CACHE_TEAM_TTL=3600           # team profiles (1 hour)
CACHE_MAX_ENTRIES=1024        # max LRU entries in MemoryCache

# ── Feature Flags ──────────────────────────────────────────────────────────────
# Set to "false" or "0" to disable. Any other value enables.
FEATURE_LIVE_UPDATES=true
FEATURE_REALTIME_SIM=true
FEATURE_STANDINGS=true
FEATURE_STATS=true

# ── BFF API Configuration ──────────────────────────────────────────────────────
# Rate limit applied to the Next.js /api/* routes (requests per minute per IP).
API_RATE_LIMIT_PER_MINUTE=60
# Comma-separated allowed origins for CORS on the API routes.
CORS_ORIGINS=http://localhost:3000
